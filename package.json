{
  "name": "xstack",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rsbuild",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "start": "srvx --prod -s ../client dist/server/index.js",
    "postinstall": "prisma generate",
    "db:dev": "prisma dev --name xstack",
    "db:dev:detach": "prisma dev --name xstack --detach",
    "db:dev:stop": "prisma dev stop xstack",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@scalar/hono-api-reference": "^0.11.5",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.19",
    "@tanstack/router-plugin": "^1.168.14",
    "better-auth": "^1.6.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.27",
    "lucide-react": "^1.21.0",
    "openai": "^6.44.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "srvx": "^0.11.16",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.5",
    "@rsbuild/plugin-react": "^2.0.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tailwindcss": "^1.3.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
