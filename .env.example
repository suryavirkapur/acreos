# 1. start local postgres: pnpm db:dev:detach
# 2. run `pnpm exec prisma dev ls` and copy the postgres:// TCP url into DATABASE_URL
DATABASE_URL="postgres://postgres:postgres@localhost:51218/template1?sslmode=disable&connection_limit=10&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Optional: use Google Gemini (OpenAI-compatible) when OPENAI_API_KEY is not set
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"
